# 배포용 환경변수 템플릿.
#
# 복사해서 프로필별 파일을 만든다. 실제 비밀값이 든 파일은 저장소에 커밋하지 않는다
# (.gitignore의 .env* 규칙 + .dockerignore가 빌드 컨텍스트에서도 막는다).
#
#   cp deploy/.env.deploy.example .env                     # prod
#   cp deploy/.env.deploy.example deploy/.env.rehearsal    # 로컬 리허설
#   cp deploy/.env.deploy.example deploy/.env.restore      # 복구 리허설
#
# 실행은 항상 wrapper를 거친다 — raw docker compose를 쓰면 preflight 검사가
# 통째로 건너뛰어진다.
#
#   deploy/stack.sh prod up -d

# ── 항상 필수 ────────────────────────────────────────────────────────────────
# 누락되면 deploy/stack.sh의 preflight가 컨테이너를 띄우기 전에 멈춘다.

DB_USER=root
DB_PASSWORD=
DB_NAME=paiM

# 32바이트 이상. 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
# 누락·약한 값이면 서버 기동 자체가 중단된다(backend/api/auth.py).
PAIM_JWT_SECRET=

# 세션 대화 암호화 키 (AES-256-GCM, base64 32바이트).
# 생성: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
#
# ⚠ 이 키를 잃으면 DB를 복구해도 기존 채팅 기록을 영구히 복호화할 수 없다.
#    데이터 백업과 **분리된** 비밀 저장소에 따로 보관할 것.
SESSION_MEMORY_KEY=

# 벡터 임베딩용. LLM_PROVIDER와 무관하게 항상 필요하다 —
# backend/db/chroma.py가 OpenAI 임베딩(text-embedding-3-small)을 쓴다.
# 누락 시 기동과 /health는 통과하고 적재·검색에서 실패한다.
OPENAI_API_KEY=

# ── LLM provider ─────────────────────────────────────────────────────────────
# 운영에서는 openai 또는 claude만 쓸 수 있다.
#   google → 구조화 추출 미지원(backend/llm/google_client.py NotImplementedError)
#   local  → 추출 팩토리 지원 분기 없음(backend/llm/factory.py ValueError)
# 둘 다 문서 업로드·저장소 sync가 실패하므로 preflight가 rollout에서 거부한다.

LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4.1-mini
# LLM_PROVIDER=claude 인 경우 필수
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# ── 도메인 · HTTPS ───────────────────────────────────────────────────────────
# 설정하면 Caddy가 Let's Encrypt 인증서를 자동 발급·갱신하고 HTTP→HTTPS로
# 리다이렉트한다. 미설정이면 :80 폴백(로컬 리허설 전용).
# production rollout에서는 필수 — preflight가 강제한다.

PAIM_DOMAIN=

# 데스크톱 앱이 접속할 origin. 배포 후 실제 값으로 교체해야 한다.
CORS_ORIGINS=http://127.0.0.1:1420,http://localhost:1420,tauri://localhost,http://tauri.localhost

# ── 포트 ─────────────────────────────────────────────────────────────────────
# prod는 기본값(80/443)을 쓴다. 리허설·복구 프로필은 같은 호스트에서 동시에
# 뜰 수 있어야 하므로 반드시 다른 값으로 옮긴다.
#   deploy/.env.rehearsal → 8080 / 8443
#   deploy/.env.restore   → 8081 / 8444
# PAIM_HTTP_PORT=80
# PAIM_HTTPS_PORT=443

# ── 이미지 태그 ──────────────────────────────────────────────────────────────
# 롤백하려면 배포마다 불변 태그가 있어야 한다. 같은 이름을 계속 덮으면
# "이전 태그로 되돌리기"를 실행할 대상이 없다.
# PAIM_IMAGE=paim-backend:<git-sha>

# ── GitHub App (선택 — 설정하려면 완전한 조합이어야 한다) ────────────────────
# 하나라도 채우면 preflight가 나머지를 요구한다. 부분 설정이 가장 위험하다
# (기동과 /health는 통과하고 사용 시점에 503).
#
# 하나도 설정하지 않으면 기능이 꺼진 것으로 간주한다. 이때 /github/app/* 는
# 503이고 비공개 저장소를 쓸 수 없다. 공개 저장소는 비인증 호출로 동작하지만
# GitHub REST 한도가 IP당 60회/시간이라 팀 사용량에는 부족하다.
#
# 설치 URL — 둘 중 하나
# GITHUB_APP_SLUG=
# GITHUB_APP_INSTALL_URL=
# installation token
# GITHUB_APP_ID=
# 개인키 — 운영에서는 inline만 허용한다. GITHUB_APP_PRIVATE_KEY_PATH는
# backend/github/router.py가 컨테이너 내부에서 그대로 open()하므로 호스트 경로를
# 넣으면 실패한다(preflight가 rollout에서 거부).
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
