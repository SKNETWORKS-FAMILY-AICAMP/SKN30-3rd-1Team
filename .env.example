# LLM Provider 설정
# 선택지: claude | openai | google
LLM_PROVIDER=claude

# Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Google
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-1.5-pro

# ChromaDB 영구 저장 경로
CHROMA_PERSIST_DIR=.chroma

# DB
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=paiM

# API 접근 허용 origin
CORS_ORIGINS=http://127.0.0.1:1420,http://localhost:1420,tauri://localhost,http://tauri.localhost

# GitHub App
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key\n-----END RSA PRIVATE KEY-----"
# 또는 private key 파일 경로를 사용
GITHUB_APP_PRIVATE_KEY_PATH=
