# LLM Provider 설정
# 선택지: openai | claude | google | local
LLM_PROVIDER=openai

# Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=sk-placeholder-replace-with-your-key
OPENAI_MODEL=gpt-4.1-mini

# Local LLM (Ollama / vLLM / LM Studio 등 OpenAI 호환 서버)
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3

# Google
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-1.5-pro

# ChromaDB 영구 저장 경로
CHROMA_PERSIST_DIR=.chroma
# OpenAI 임베딩 전용 컬렉션명 (기존 "paiM" 컬렉션은 384-dim; OpenAI는 1536-dim으로 호환 불가)
# 기존 .chroma 데이터가 있으면 전체 재인덱싱 후 이 컬렉션을 사용해야 함
CHROMA_COLLECTION_NAME=paiM_openai_v1
# 임베딩 모델 — chroma.py(적재)와 qa_engine.py(검색) 양쪽이 동일 모델을 사용해야 벡터가 맞음
EMBED_MODEL=text-embedding-3-small

# 업로드 파일 저장 루트 경로 (로컬 개발용)
# AWS 배포 시 backend/storage.py를 S3 구현으로 교체
UPLOAD_DIR=data/uploads

# DB
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=paiM

# 세션 대화 암호화 키 (AES-256-GCM, base64 인코딩된 32바이트)
# 생성 예: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
SESSION_MEMORY_KEY=your_base64_encoded_32byte_key

# API 접근 허용 origin
CORS_ORIGINS=http://127.0.0.1:1420,http://localhost:1420,tauri://localhost,http://tauri.localhost

# BackgroundTask stale 정리 (선택 — 기본 30분, 0 이하이면 비활성화)
# 서버 재시작 시 processing/syncing 상태가 N분 이상 된 작업을 failed로 전환
# BACKGROUND_TASK_STALE_MINUTES=30

# 개발용 사용자 설정 (선택 — 실제 로그인 구현 전 DEV_USER_ID 기반 fallback)
# DEV_USER_ID 설정 시 project create/access 요청에서 users row를 자동 보장(upsert)함.
# 미설정(기본값) 시 모든 project access check가 no-op으로 동작.
# 운영 인증(JWT/session/OAuth) 도입 시 이 항목들은 제거할 것.
# DEV_USER_ID=1
# DEV_USER_EMAIL=dev@local
# DEV_USER_NAME=Dev User

# GitHub App
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key\n-----END RSA PRIVATE KEY-----"
# 또는 private key 파일 경로를 사용
GITHUB_APP_PRIVATE_KEY_PATH=
